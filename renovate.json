{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "kubernetes": {
    "managerFilePatterns": [
      "/applications/.+\\.yaml$/",
      "/networking/.+\\.yaml$/",
      "/security/.+\\.yaml$/",
      "/storage/.+\\.yaml$/",
      "/observability/.+\\.yaml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": ["/ci-cd/argocd/.+\\.yaml$/"]
  },
  "packageRules": [
    {
      "description": "Group container image updates",
      "matchManagers": ["kubernetes"],
      "groupName": "container images"
    },
    {
      "description": "Group Helm chart updates",
      "matchManagers": ["argocd"],
      "groupName": "helm charts"
    }
  ]
}
