# Copy to shared/secrets.auto.tfvars and fill in your values.
# This file is gitignored. Back it up alongside the tfstate.

# ============================================================
# Proxmox
# ============================================================
proxmox_endpoint  = "https://<PROXMOX_VIP_OR_FIRST_NODE>:8006"
proxmox_username  = "root@pam"
proxmox_password  = "<YOUR_PROXMOX_ROOT_PW>"   # or API token value
proxmox_insecure  = true                        # flip to false once you have valid certs
proxmox_node_name = "pve-1"                     # must match a node's pve_node field below

# ============================================================
# Talos cluster
# ============================================================
# VIP must be on the same L2 as the nodes, outside DHCP scope, and
# not assigned to any physical machine.
talos_cluster_vip = "<TALOS_API_VIP>"           # e.g. 192.168.1.100

# ============================================================
# Nodes — one entry per Talos VM
# ============================================================
# 3-node hyperconverged: each Proxmox box hosts one Talos VM that is BOTH
# control plane and worker (allowSchedulingOnControlPlanes=true). Don't reorder
# or rename keys after first apply (Longhorn diskUUID mismatch).
#
# Generate MACs with: printf "BC:24:11:%02X:%02X:%02X\n" $((RANDOM%256)) $((RANDOM%256)) $((RANDOM%256))
# Reserve each MAC as a static DHCP lease in your router so node IPs don't drift.

nodes = {
  "firelink-1" = {
    vm_id       = 100
    pve_node    = "pve-1"
    proxmox_ip  = "<PROXMOX_1_IP>"
    cpu_cores   = 4
    memory_mb   = 16384
    disk_gb     = 100
    ip_address  = "<NODE_1_IP>"
    mac_address = "<MAC_1>"
  }
  "firelink-2" = {
    vm_id       = 101
    pve_node    = "pve-2"
    proxmox_ip  = "<PROXMOX_2_IP>"
    cpu_cores   = 4
    memory_mb   = 16384
    disk_gb     = 100
    ip_address  = "<NODE_2_IP>"
    mac_address = "<MAC_2>"
  }
  "firelink-3" = {
    vm_id       = 102
    pve_node    = "pve-3"
    proxmox_ip  = "<PROXMOX_3_IP>"
    cpu_cores   = 4
    memory_mb   = 16384
    disk_gb     = 100
    ip_address  = "<NODE_3_IP>"
    mac_address = "<MAC_3>"
  }
}

# ============================================================
# Bootstrap-time secrets
# ============================================================
# These can also be set via TF_VAR_<name> env vars (preferred — keeps them out
# of the tfvars file). Generate the Cloudflare API token in the dashboard with
# Zone:DNS:Edit + Zone:Zone:Read scoped to your cert-manager-managed zones.
cloudflare_api_token = "<CLOUDFLARE_API_TOKEN>"
